# PostgreSQL container credentials used by docker-compose
ESFL_DB_USER=admin
ESFL_DB_PASSWORD=password
ESFL_DB_NAME=fantasy_league

# Backend database URL used by Prisma when running the NestJS service directly
DATABASE_URL="postgresql://admin:password@localhost:5432/fantasy_league?schema=public"

# Backend runtime
PORT=3000
JWT_ACCESS_SECRET="super-secret-access-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-in-production"
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"
FRONTEND_URL="http://localhost:5173"
PANDASCORE_API_TOKEN="your-pandascore-api-token"

# Local-only dev dashboard
DEV_DASHBOARD_PORT=4174
DEV_DASHBOARD_BACKEND_URL="http://localhost:3000"
DEV_DASHBOARD_TOKEN="local-dev-dashboard"
DEV_DASHBOARD_ALLOW_SQL=false