# Backend Service Environment Variables

# The port the backend server will listen on
PORT=3000

# PostgreSQL database connection string (used by Prisma)
DATABASE_URL="postgresql://admin:password@localhost:5432/fantasy_league?schema=public"

# Secret keys used for signing JWT access and refresh tokens
JWT_ACCESS_SECRET="super-secret-access-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-in-production"

# Google OAuth 2.0 Client credentials (obtain from Google Developer Console)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# The callback URL Google redirects users to after successful authentication
# This should match one of the authorized redirect URIs in Google Developer Console
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# The URL of the frontend application (used for CORS and OAuth redirects)
FRONTEND_URL="http://localhost:5173"

# API Token for Pandascore (used by Ingestion service to fetch esports data)
PANDASCORE_API_TOKEN="your-pandascore-api-token"
