generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  username          String         @unique
  passwordHash      String?        @map("password_hash")
  googleId          String?        @unique @map("google_id")
  avatarUrl         String?        @map("avatar_url")
  role              Role           @default(USER)
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  auditLogs         AuditLog[]
  leagueMemberships LeagueMember[]
  refreshTokens     RefreshToken[]
  rosters           Roster[]

  @@map("users")
}

model League {
  id                 String         @id @default(cuid())
  name               String
  games              Game[]         @default([])
  tournaments        String[]       @default([])
  rosterSize         Int            @map("roster_size")
  cooldownDays       Int            @map("cooldown_days")
  inviteCode         String         @unique @map("invite_code")
  maxMembers         Int            @default(12) @map("max_members")
  createdById        String         @map("created_by_id")
  onlyCreatorInvites Boolean        @default(false) @map("only_creator_invites")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  members            LeagueMember[]
  rosters            Roster[]

  @@map("leagues")
}

model LeagueMember {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  leagueId   String   @map("league_id")
  totalScore Float    @default(0) @map("total_score")
  joinedAt   DateTime @default(now()) @map("joined_at")
  league     League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
  @@map("league_members")
}

model Team {
  id         String      @id @default(cuid())
  name       String
  acronym    String?
  imageUrl   String?     @map("image_url")
  location   String?
  game       Game
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  matchesA   Match[]     @relation("TeamA")
  matchesB   Match[]     @relation("TeamB")
  wonMatches Match[]     @relation("MatchWinner")
  players    ProPlayer[]

  @@map("teams")
}

model ProPlayer {
  id           String           @id @default(cuid())
  name         String
  teamId       String?          @map("team_id")
  game         Game
  role         String
  imageUrl     String?          @map("image_url")
  nationality  String?
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  performances DayPerformance[]
  team         Team?            @relation(fields: [teamId], references: [id])
  rosterPicks  RosterPick[]

  @@map("pro_players")
}

model MatchDay {
  id           String           @id @default(cuid())
  date         DateTime         @db.Date
  game         Game
  lockTime     DateTime         @map("lock_time")
  status       MatchDayStatus   @default(OPEN)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  performances DayPerformance[]
  matches      Match[]          @relation("MatchDayMatches")
  rosters      Roster[]

  @@unique([date, game])
  @@map("match_days")
}

model Match {
  id             String    @id @default(cuid())
  matchDayId     String    @map("match_day_id")
  teamAId        String    @map("team_a_id")
  teamBId        String    @map("team_b_id")
  winnerId       String?   @map("winner_id")
  scheduledAt    DateTime  @map("scheduled_at")
  status         String    @default("not_started")
  teamAScore     Int?      @map("team_a_score")
  teamBScore     Int?      @map("team_b_score")
  tournamentName String?   @map("tournament_name")
  streamUrl      String?   @map("stream_url")
  matchType      String?   @map("match_type")
  numberOfGames  Int?      @map("number_of_games")
  games          Json?
  finishedAt     DateTime? @map("finished_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  matchDay       MatchDay  @relation("MatchDayMatches", fields: [matchDayId], references: [id], onDelete: Cascade)
  teamA          Team      @relation("TeamA", fields: [teamAId], references: [id])
  teamB          Team      @relation("TeamB", fields: [teamBId], references: [id])
  winner         Team?     @relation("MatchWinner", fields: [winnerId], references: [id])

  @@map("matches")
}

model DayPerformance {
  id          String    @id @default(cuid())
  matchDayId  String    @map("match_day_id")
  proPlayerId String    @map("pro_player_id")
  rawStats    Json      @map("raw_stats")
  score       Float?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  matchDay    MatchDay  @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  proPlayer   ProPlayer @relation(fields: [proPlayerId], references: [id], onDelete: Cascade)

  @@unique([matchDayId, proPlayerId])
  @@map("day_performances")
}

model Roster {
  id         String       @id @default(cuid())
  userId     String       @map("user_id")
  leagueId   String       @map("league_id")
  matchDayId String       @map("match_day_id")
  status     RosterStatus @default(PENDING)
  totalScore Float?       @map("total_score")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  picks      RosterPick[]
  league     League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  matchDay   MatchDay     @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId, matchDayId])
  @@map("rosters")
}

model RosterPick {
  id          String    @id @default(cuid())
  rosterId    String    @map("roster_id")
  proPlayerId String    @map("pro_player_id")
  pickOrder   Int       @map("pick_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  proPlayer   ProPlayer @relation(fields: [proPlayerId], references: [id], onDelete: Cascade)
  roster      Roster    @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@unique([rosterId, proPlayerId])
  @@map("roster_picks")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  payload    Json
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum Game {
  LEAGUE_OF_LEGENDS
  COUNTER_STRIKE
  ROCKET_LEAGUE
  VALORANT
}

enum MatchDayStatus {
  OPEN
  LOCKED
  SCORED
}

enum RosterStatus {
  PENDING
  LOCKED
  SCORED
}

enum Role {
  USER
  ADMIN
}
