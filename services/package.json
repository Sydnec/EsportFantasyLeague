{
  "name": "services",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\" --fix",
    "build:gateway": "nest build gateway",
    "build:backend": "nest build backend",
    "build:esport": "nest build esport-adapter",
    "build:scoring": "nest build scoring",
    "build:all": "npm run build:gateway && npm run build:backend && npm run build:esport && npm run build:scoring",
    "start:dev": "concurrently -k -n \"GATEWAY,BACKEND,ESPORT,SCORING\" -c \"bgCyan.bold,bgBlue.bold,bgYellow.bold,bgMagenta.bold\" \"npm run start:dev:gateway\" \"npm run start:dev:backend\" \"npm run start:dev:esport\" \"npm run start:dev:scoring\"",
    "start:dev:gateway": "npx dotenv-cli -e apps/gateway/.env -- nest start gateway --watch",
    "start:dev:backend": "npx dotenv-cli -e apps/backend/.env -- nest start backend --watch",
    "start:dev:esport": "npx dotenv-cli -e apps/esport-adapter/.env -- nest start esport-adapter --watch",
    "start:dev:scoring": "npx dotenv-cli -e apps/scoring/.env -- nest start scoring --watch",
    "start:prod:gateway": "npx dotenv-cli -e apps/gateway/.env -- node dist/apps/gateway/main",
    "start:prod:backend": "npx dotenv-cli -e apps/backend/.env -- node dist/apps/backend/main",
    "start:prod:esport": "npx dotenv-cli -e apps/esport-adapter/.env -- node dist/apps/esport-adapter/main",
    "start:prod:scoring": "npx dotenv-cli -e apps/scoring/.env -- node dist/apps/scoring/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e:gateway": "jest --config ./apps/gateway/test/jest-e2e.json",
    "test:e2e:backend": "jest --config ./apps/backend/test/jest-e2e.json",
    "test:e2e:esport": "jest --config ./apps/esport-adapter/test/jest-e2e.json",
    "db:push:backend": "npx dotenv-cli -e apps/backend/.env -- prisma db push --schema=apps/backend/prisma/schema.prisma",
    "db:generate:backend": "npx dotenv-cli -e apps/backend/.env -- prisma generate --schema=apps/backend/prisma/schema.prisma",
    "db:push:esport": "npx dotenv-cli -e apps/esport-adapter/.env -- prisma db push --schema=apps/esport-adapter/prisma/schema.prisma",
    "db:generate:esport": "npx dotenv-cli -e apps/esport-adapter/.env -- prisma generate --schema=apps/esport-adapter/prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/client": "^6.15.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^2.0.1",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "google-auth-library": "^10.9.0",
    "http-proxy-middleware": "^4.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/http-proxy-middleware": "^0.19.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.15.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/shared(|/.*)$": "<rootDir>/libs/shared/src/$1"
    }
  }
}
