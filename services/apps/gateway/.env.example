# Port d'écoute du Gateway
PORT=3000

# URLs des services sous-jacents
BACKEND_SERVICE_URL=http://localhost:3001
ESPORT_SERVICE_URL=http://localhost:3002

# URL du frontend (autorisée en CORS)
FRONTEND_URL=http://localhost:5173

# Doit être IDENTIQUE au JWT_SECRET du Backend Service : le gateway ne fait que
# vérifier les tokens signés par le backend, avec la même clé.
JWT_SECRET=changesubmitsecretinproduction
