# Port d'écoute local du service esport adapter
PORT=3002

# Connexion Base de Données (Schéma esport_db)
DATABASE_URL="postgresql://db_user:db_password@localhost:5432/db_name?schema=esport_db"

# Connexion RabbitMQ
RABBITMQ_URL=amqp://rmq_user:rmq_password@localhost:5672

# Token API Pandascore
PANDASCORE_API_TOKEN=placeholder-pandascore-api-token
